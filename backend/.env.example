PORT=5000

# Supabase Dashboard > Connect > Transaction pooler is recommended for Vercel/serverless.
# Example:
# DATABASE_URL=postgres://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=
DATABASE_SSL=true
DB_POOL_MAX=5

# Local frontend:
CORS_ORIGIN=http://localhost:5173

# Production frontend example:
# CORS_ORIGIN=https://your-frontend.vercel.app
